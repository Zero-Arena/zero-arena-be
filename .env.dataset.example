# zero-arena-bacend — DATASET service only.
# Copy this into `.env` on the host that runs `bacend dataset {ingest,upload,start}`.
# The dataset service does NOT need any oracle key.
#
# What this service does: polls Binance for OHLCV candles, writes a canonical CSV,
# uploads it to 0G Storage, and rotates `datasets.lock.json`. It pays gas with
# OPERATOR_PRIVATE_KEY. Nothing else.

# ─── Binance fetcher ──────────────────────────────────────────────────────

BACKEND_SYMBOL=BTCUSDT
BACKEND_INTERVAL=15m
BACKEND_BOOTSTRAP_START=2025-01-01

# Scheduler cadence in minutes. The fetcher aligns to wall-clock boundaries.
BACKEND_POLL_MINUTES=30
# Seconds after a boundary before we hit Binance (gives the exchange time
# to finalize the last candle).
BACKEND_GRACE_SECONDS=20

# When true, `dataset:start` also uploads each tick to 0G Storage.
BACKEND_AUTO_UPLOAD=false

# ─── 0G credentials (only required for `dataset:upload`) ─────────────────

ZA_RPC=https://evmrpc-testnet.0g.ai
ZA_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Workspace operator wallet — pays gas for canonical-dataset uploads.
# Separate from the SDK consumer's wallet (which lives in their own project).
OPERATOR_PRIVATE_KEY=

# Contract addresses (the dataset service touches storage only, but the
# ZeroArena facade validates these on construction).
ZA_ADDR_CERT=0x77f29d2a7BcAC679812d9a0FB1c7508eDA6B087e
ZA_ADDR_INFT=0xF7162ecbdB11DE4704043D4aF93B4030AD61700e
ZA_ADDR_ORACLE=0x733667CEBB27e310a8fb60799Af73A8C1fe501b2
