# zero-arena-bacend — PAPER service only.
# Copy this into `.env` on the host that runs `bacend paper {start,backfill}`.
#
# What this service does: subscribes to a real-time Binance kline stream,
# drives a PaperEngine bar-by-bar, and commits one EpochCommitted tx per
# barsPerEpoch boundary to LiveCertificate on Galileo. One daemon = one
# iNFT.

# ─── 0G endpoints ─────────────────────────────────────────────────────────

ZA_RPC=https://evmrpc-testnet.0g.ai

# Operator wallet — must be in LiveCertificate.authorizedUpdaters.
# Default v0.2 deployment authorizes Wallet A (the deployer).
OPERATOR_PRIVATE_KEY=

# ─── v0.2 paper-engine contracts (chain 16602) ───────────────────────────

ZA_ADDR_LIVE_CERT=0x2c71fe022E4698f8fD63384A19Cd69D72a714b4d
ZA_ADDR_SEASON=0x8fb87CE34b4e8F4C65eeB6752b0168EC37806CF3

# ─── Per-run targeting ────────────────────────────────────────────────────

# iNFT this daemon drives. Owner must have called LiveCertificate.start()
# for this token first.
PAPER_TOKEN_ID=

# Absolute path to the agent module (default-exports a class extending Agent).
PAPER_AGENT_MODULE=

# Static cert runHash for the iNFT above — must equal AgentCertificate.get(certId).runHash.
PAPER_GENESIS_HASH=

# Binance kline stream (lowercase symbol).
PAPER_SYMBOL=btcusdt
PAPER_INTERVAL=15m
PAPER_MARKET=spot

# 96 = one day at 15m. Use 4 for fast demo backfills.
PAPER_BARS_PER_EPOCH=96

# Set to true to skip on-chain commits (drives engine + prints epoch hashes only).
PAPER_DRY_RUN=false

# Optional — used only by `paper backfill`. How many days back to replay.
# PAPER_BACKFILL_DAYS=7
