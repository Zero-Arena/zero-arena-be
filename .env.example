# zero-arena-bacend — runtime config. Two services share this file.
# Copy to `.env` and fill in.

# ─── dataset service ──────────────────────────────────────────────────────

BACKEND_SYMBOL=BTCUSDT
BACKEND_INTERVAL=15m
BACKEND_BOOTSTRAP_START=2025-01-01

# Scheduler cadence in minutes. The fetcher aligns to wall-clock boundaries.
BACKEND_POLL_MINUTES=30
# Seconds after a boundary before we hit Binance (gives the exchange time
# to finalize the last candle).
BACKEND_GRACE_SECONDS=20

# When true, `dataset:start` also uploads each tick to 0G Storage.
BACKEND_AUTO_UPLOAD=false

# ─── 0G credentials (used by dataset:upload) ─────────────────────────────

ZA_RPC=https://evmrpc-testnet.0g.ai
ZA_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Operator wallet that pays gas for dataset uploads. Funded with Galileo OG.
PRIVATE_KEY=

# Required by the SDK's configFromEnv; the dataset service only uses
# storage, but the ZeroArena facade validates these on construction.
ZA_ADDR_CERT=
ZA_ADDR_INFT=
ZA_ADDR_ORACLE=

# ─── oracle service ──────────────────────────────────────────────────────

# Required for `oracle:serve`. The key the on-chain `ReencryptionOracle.signer()`
# resolves to. This is the workspace operator's key, NOT something an SDK
# consumer ever holds.
ORACLE_PRIVATE_KEY=

ORACLE_HOST=0.0.0.0
ORACLE_PORT=8787

# Optional bearer-token gate. If set, callers of POST /sign-transfer-proof
# must include `Authorization: Bearer <token>`. Recommended for anything
# not on localhost.
# ORACLE_AUTH_TOKEN=
