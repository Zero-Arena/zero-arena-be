# zero-arena-bacend — ONBOARD service only.
# Copy this into `.env` on the host that runs `bacend onboard serve`.
#
# What this service does: HTTP endpoint that lets iNFT owners delegate
# their paper daemon to Zero Arena's backend. Owners send their agent
# source + a signed authorization; we spawn a per-token `bacend paper
# start` child process whose `LiveCertificate.update()` calls are signed
# by the operator wallet defined here.
#
# Before an owner can onboard their tokenId, they must call:
#   LiveCertificate.authorizeUpdater(tokenId, <operator address below>)
# from the iNFT owner wallet.

# ─── Operator (Zero Arena's wallet) ──────────────────────────────────────

# Wallet that the owner has authorized as an updater for their tokenId.
# Pays gas for every EpochCommitted tx.
OPERATOR_PRIVATE_KEY=

# ─── 0G chain endpoints ───────────────────────────────────────────────────

ZA_RPC=https://evmrpc-testnet.0g.ai

# ─── v0.2 contracts (chain 16602) ─────────────────────────────────────────

ZA_ADDR_INFT=0xF7162ecbdB11DE4704043D4aF93B4030AD61700e
ZA_ADDR_LIVE_CERT=0x2c71fe022E4698f8fD63384A19Cd69D72a714b4d

# ─── HTTP bind ────────────────────────────────────────────────────────────

ONBOARD_HOST=0.0.0.0
ONBOARD_PORT=8788

# Optional bearer-token gate. Strongly recommended in production.
# ONBOARD_AUTH_TOKEN=

# Where to write decrypted/parsed agent sources at runtime. Ephemeral.
ONBOARD_AGENT_DIR=./data/onboard/agents
